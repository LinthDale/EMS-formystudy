# Copy to .env and adjust for your local environment.
# .env is gitignored — keep secrets there only.

# --- Database ---
POSTGRES_PASSWORD=postgres
AUTHENTICATOR_PASSWORD=changeme

# --- device-service DB roles (PRD-0003, ADR-017) ---
# Per-role login passwords for the two connection pools (device_service_ai / device_service_ops).
# After migration 010 creates the roles, set passwords with:
#   set -a; source .env; set +a; bash infra/timescaledb/set_role_passwords.sh
# Rotate for production (Promotion Checklist P-7).
DB_AI_PASSWORD=changeme_ai
DB_OPS_PASSWORD=changeme_ops

# --- device-service X-API-Key channels (PRD-0003, FR-310) ---
OPS_API_KEY=changeme_ops_key
INGEST_API_KEY=changeme_ingest_key
AI_API_KEY=changeme_ai_key

# --- Grafana ---
GRAFANA_PASSWORD=admin

# --- Telegram (Grafana Alerting contact point) ---
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=7171144544
